# LLM provider (populate whichever one you use)
GEMINI_API_KEY=
OPENAI_API_KEY=

# Vector store
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Observability (LangFuse) -- see docker-compose.langfuse.yml for local self-hosting.
# Create a project in the LangFuse UI (http://localhost:3000) to get these keys.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3000

# App metadata
ENVIRONMENT=development
